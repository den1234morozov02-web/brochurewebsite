---
import { Icon } from "astro-icon/components";
import { useTranslations } from "../i18n/ui";
import { site, type Locale } from "../data/site";
import BookingForm from "./BookingForm.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const waText = encodeURIComponent(
  locale === "uk"
    ? "Вітаю! Хочу записатися на сеанс."
    : "Hello! I'd like to book an appointment."
);

const contactBtns = [
  {
    href: `https://wa.me/${site.whatsapp}?text=${waText}`,
    icon: "lucide:message-circle",
    label: t("contact.whatsapp"),
    value: site.phoneDisplay,
    external: true,
  },
  {
    href: `tel:${site.phone}`,
    icon: "lucide:phone",
    label: t("contact.call"),
    value: site.phoneDisplay,
    external: false,
  },
  {
    href: `mailto:${site.email}`,
    icon: "lucide:mail",
    label: t("contact.email"),
    value: site.email,
    external: false,
  },
];
---

<section id="contact" class="bg-cream py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-4xl text-ink md:text-5xl">{t("contact.title")}</h2>
      <p class="mt-4 text-ink/65">{t("contact.subtitle")}</p>
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Форма записи -->
      <div class="rounded-2xl bg-white p-7 shadow-sm ring-1 ring-cream-deep">
        <BookingForm locale={locale} />
      </div>

      <!-- Контакты, адрес, часы, карта -->
      <div class="space-y-8">
        <div class="grid gap-3 sm:grid-cols-3">
          {
            contactBtns.map((b) => (
              <a
                href={b.href}
                target={b.external ? "_blank" : undefined}
                rel={b.external ? "noopener" : undefined}
                class="flex flex-col items-center gap-1 rounded-xl bg-white p-4 text-center shadow-sm ring-1 ring-cream-deep transition-colors hover:ring-sage"
              >
                <Icon name={b.icon} class="h-6 w-6 text-sage-deep" />
                <span class="text-sm font-medium text-ink">{b.label}</span>
                <span class="break-all text-xs text-ink/55">{b.value}</span>
              </a>
            ))
          }
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <h3 class="flex items-center gap-2 font-serif text-xl text-ink">
              <Icon name="lucide:map-pin" class="h-5 w-5 text-sage" />
              {t("contact.address")}
            </h3>
            <p class="mt-2 text-ink/70">{site.address[locale]}</p>
            <a
              href={site.mapLink}
              target="_blank"
              rel="noopener"
              class="mt-1 inline-block text-sm text-sage underline-offset-2 hover:underline"
            >
              {t("contact.directions")}
            </a>
          </div>
          <div>
            <h3 class="flex items-center gap-2 font-serif text-xl text-ink">
              <Icon name="lucide:clock" class="h-5 w-5 text-sage" />
              {t("contact.hours")}
            </h3>
            <ul class="mt-2 space-y-1 text-sm text-ink/70">
              {
                site.hours[locale].map((h) => (
                  <li class="flex justify-between gap-4">
                    <span>{h.days}</span>
                    <span class="text-ink/55">{h.time}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl ring-1 ring-cream-deep">
          <iframe
            src={site.mapEmbed}
            title="Map"
            class="h-64 w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
