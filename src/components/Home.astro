---
import Layout from "../layouts/Layout.astro";
import Header from "./Header.astro";
import Hero from "./Hero.astro";
import About from "./About.astro";
import Services from "./Services.astro";
import Rituals from "./Rituals.astro";
import Pricing from "./Pricing.astro";
import Certificates from "./Certificates.astro";
import Contact from "./Contact.astro";
import Footer from "./Footer.astro";
import { type Locale } from "../data/site";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<Layout locale={locale}>
  <Header locale={locale} />
  <main>
    <Hero locale={locale} />
    <About locale={locale} />
    <Certificates locale={locale} />
    <Services locale={locale} />
    <Rituals locale={locale} />
    <Pricing locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>

<script>
  import "../scripts/forms.ts";
</script>
