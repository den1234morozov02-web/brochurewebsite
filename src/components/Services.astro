---
import { Icon } from "astro-icon/components";
import { useTranslations, localePath } from "../i18n/ui";
import { type Locale } from "../data/site";
import { services } from "../data/services";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const base = localePath(locale);
---

<section id="services" class="bg-sage-deep py-20 text-cream md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-4xl text-gold-soft md:text-5xl">{t("services.title")}</h2>
      <p class="mt-4 text-cream/75">{t("services.subtitle")}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <article class="flex flex-col rounded-2xl bg-cream/5 p-6 ring-1 ring-cream/10 transition-colors hover:ring-gold/40">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-gold/15 text-gold">
              <Icon name={`lucide:${s.icon}`} class="h-6 w-6" />
            </span>
            <h3 class="mt-5 font-serif text-2xl text-cream">{s.name[locale]}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-cream/70">{s.desc[locale]}</p>
            <div class="mt-5 flex items-center justify-between border-t border-cream/10 pt-4">
              <span class="text-sm text-cream/60">
                {s.duration} {t("services.min")}
              </span>
              <span class="font-serif text-xl text-gold-soft">
                €{s.price}
                {s.priceNote && <span class="ml-1 text-xs text-cream/50">{s.priceNote[locale]}</span>}
              </span>
            </div>
            <a
              href={`${base}/#contact`}
              class="mt-4 inline-flex items-center justify-center rounded-full border border-gold/50 px-4 py-2 text-sm text-gold-soft transition-colors hover:bg-gold hover:text-ink"
            >
              {t("services.book")}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
